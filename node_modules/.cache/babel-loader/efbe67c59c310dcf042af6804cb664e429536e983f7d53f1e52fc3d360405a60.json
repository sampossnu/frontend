{"ast":null,"code":"import{useEffect,useRef,useState}from'react';export function useInView(){let threshold=arguments.length>0&&arguments[0]!==undefined?arguments[0]:0.15;const ref=useRef(null);const[inView,setInView]=useState(false);useEffect(()=>{const el=ref.current;if(!el)return;const obs=new IntersectionObserver(_ref=>{let[entry]=_ref;if(entry.isIntersecting){setInView(true);obs.unobserve(el);}},{threshold});obs.observe(el);return()=>obs.disconnect();},[threshold]);return{ref,inView};}","map":{"version":3,"names":["useEffect","useRef","useState","useInView","threshold","arguments","length","undefined","ref","inView","setInView","el","current","obs","IntersectionObserver","_ref","entry","isIntersecting","unobserve","observe","disconnect"],"sources":["C:/Users/emily/Desktop/driveguard/src/hooks/useInView.ts"],"sourcesContent":["import { useEffect, useRef, useState } from 'react';\n\nexport function useInView(threshold = 0.15) {\n  const ref = useRef<HTMLDivElement>(null);\n  const [inView, setInView] = useState(false);\n\n  useEffect(() => {\n    const el = ref.current;\n    if (!el) return;\n    const obs = new IntersectionObserver(\n      ([entry]) => { if (entry.isIntersecting) { setInView(true); obs.unobserve(el); } },\n      { threshold }\n    );\n    obs.observe(el);\n    return () => obs.disconnect();\n  }, [threshold]);\n\n  return { ref, inView };\n}"],"mappings":"AAAA,OAASA,SAAS,CAAEC,MAAM,CAAEC,QAAQ,KAAQ,OAAO,CAEnD,MAAO,SAAS,CAAAC,SAASA,CAAA,CAAmB,IAAlB,CAAAC,SAAS,CAAAC,SAAA,CAAAC,MAAA,IAAAD,SAAA,MAAAE,SAAA,CAAAF,SAAA,IAAG,IAAI,CACxC,KAAM,CAAAG,GAAG,CAAGP,MAAM,CAAiB,IAAI,CAAC,CACxC,KAAM,CAACQ,MAAM,CAAEC,SAAS,CAAC,CAAGR,QAAQ,CAAC,KAAK,CAAC,CAE3CF,SAAS,CAAC,IAAM,CACd,KAAM,CAAAW,EAAE,CAAGH,GAAG,CAACI,OAAO,CACtB,GAAI,CAACD,EAAE,CAAE,OACT,KAAM,CAAAE,GAAG,CAAG,GAAI,CAAAC,oBAAoB,CAClCC,IAAA,EAAa,IAAZ,CAACC,KAAK,CAAC,CAAAD,IAAA,CAAO,GAAIC,KAAK,CAACC,cAAc,CAAE,CAAEP,SAAS,CAAC,IAAI,CAAC,CAAEG,GAAG,CAACK,SAAS,CAACP,EAAE,CAAC,CAAE,CAAE,CAAC,CAClF,CAAEP,SAAU,CACd,CA